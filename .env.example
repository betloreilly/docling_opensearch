# Docling SaaS (IBM docling-serve) — required for document parsing
DOCLING_SERVICE_URL=https://your-docling-service-url
DOCLING_API_KEY=your-api-key
# Alternate name also accepted by the backend: DOCLING_SERVICE_API_KEY

# OpenSearch (matches docker-compose defaults)
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=YourStrongPass123!
OPENSEARCH_INDEX=docling_demo
OPENSEARCH_HYBRID_PIPELINE=docling-hybrid-pipeline

# Local embedding model — vectors are generated in the backend and indexed into OpenSearch
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIM=384

# Hybrid score fusion weights (keyword, semantic) — used by the OpenSearch search pipeline
KEYWORD_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# Chunking (structure-aware text segments sent to OpenSearch)
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=40

# Backend URL for Next.js API rewrites (see frontend/.env.local.example)
BACKEND_URL=http://127.0.0.1:8000

# Leave NEXT_PUBLIC_API_URL unset so /api is proxied via Next.js (required for PDF preview)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenSearch Dashboards (optional — inspect the index in Query Workbench)
NEXT_PUBLIC_OPENSEARCH_DASHBOARDS_URL=http://localhost:5601
NEXT_PUBLIC_OPENSEARCH_INDEX=docling_demo
