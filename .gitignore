# Secrets and local config
.env
.env.*
!.env.example
!frontend/.env.local.example
frontend/.env.local

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
npm-debug.log*

# Runtime artifacts (regenerated by ingest)
uploads/*
!uploads/.gitkeep
parsed/*
!parsed/.gitkeep

# OS and editors
.DS_Store
.idea/
.vscode/
*.swp
*~

# Optional local OpenSearch data (if bind-mounted)
opensearch-data/

# Editable diagrams and large demo media (keep PNG/GIF in docs/ for README)
docs/*.drawio
*.drawio
docs/*.mp4
docs/*.mov
